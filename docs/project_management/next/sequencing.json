    {
      "id": "codex_cli_release_trailing",
      "name": "Codex CLI Release Trailing (Parity Maintenance)",
      "source": "docs/adr/0001-codex-cli-parity-maintenance.md",
      "phases": [
        {
          "id": "C0",
          "name": "Snapshot schema + generator",
          "goals": [
            "Deterministic CLI snapshot for a given codex binary",
            "Human-reviewable diffs for commands/flags/features"
          ],
          "deliverables": [
            "Snapshot schema documented under cli_manifests/codex/",
            "Local snapshot generator tool wired into triad workflow"
          ]
        },
        {
          "id": "C1",
          "name": "Validation matrix + pinned binaries",
          "goals": [
            "Repeatable Linux gating against min supported and latest validated binaries",
            "Clear definition of validated vs supported"
          ],
          "deliverables": [
            "Pinned version pointers under cli_manifests/codex/",
            "CI/automation coverage (as defined by ADR 0001)"
          ]
        },
        {
          "id": "C2",
          "name": "JSONL + notification compatibility",
          "goals": [
            "Robust parsing across CLI version drift",
            "Fixture-backed regression coverage for known drift cases"
          ],
          "deliverables": [
            "Normalization rules documented",
            "Fixtures + tests for drift cases"
          ]
        },
        {
          "id": "C3",
          "name": "Ops playbook",
          "goals": [
            "Make release trailing procedural and low-risk",
            "Define ownership and cadence"
          ],
          "deliverables": [
            "Maintainer checklist for snapshot/diff/validate/release",
            "Trial-run checklist to move 0.61.0 -> 0.77.0 on Linux"
          ]
        }
      ]
